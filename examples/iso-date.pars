-- Match an ISO 8601 calendar date: YYYY-MM-DD.
--
-- Demonstrates bounded quantifiers: the year is exactly four digits,
-- the month and day exactly two.
--
-- Usage:
--   echo -n "2026-04-18" | pars examples/iso-date.pars
--   echo -n "2026-4-18"  | pars examples/iso-date.pars  -- rejected

use "std/abnf";

date = year "-" month "-" day !.
  where
    year  = DIGIT{4};
    month = DIGIT{2};
    day   = DIGIT{2}
  end
