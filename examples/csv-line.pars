-- Match a single CSV line: comma-separated fields, each field
-- being a run of non-comma, non-newline bytes.
--
-- Usage:
--   echo -n "alice,30,new york" | pars examples/csv-line.pars

csv_line = field (',' field)*
  where
    field_char = ['a'-'z' 'A'-'Z' '0'-'9' ' ' '-' '_' '.'];
    field      = field_char+
  end
